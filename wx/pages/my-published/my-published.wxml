<view class="container">
  <view wx:if="{{publishList.length>0}}">
    <view class="item-box" wx:for="{{publishList}}" wx:key="id" bindtap="goDetail" data-type="{{item.targetType}}" data-id="{{item.targetId}}">
      <view class="item-left">
        <view class="title">{{item.title}}</view>
        <view class="desc">{{item.content}}</view>
        <view class="time">发布时间：{{item.createTime}}</view>
      </view>
      <view class="tag">
        <text wx:if="{{item.targetType===1}}" class="tag-xian">闲置</text>
        <text wx:if="{{item.targetType===2}}" class="tag-qiu">求购</text>
        <text wx:if="{{item.targetType===3}}" class="tag-dong">动态</text>
        <text wx:if="{{item.targetType===4}}" class="tag-shi">失物</text>
      </view>
    </view>
  </view>
  <view wx:else class="empty">暂无发布内容</view>
</view>