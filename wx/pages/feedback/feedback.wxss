.container {
  padding: 24rpx;
  background-color: #f6f7f9;
  min-height: 100vh;
  box-sizing: border-box;
}

.form-item {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 36rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04), 0 6rpx 16rpx rgba(0, 0, 0, 0.05);
}

.label {
  font-size: 30rpx;
  font-weight: 600;
  color: #1d2129;
  margin-bottom: 24rpx;
  letter-spacing: 1rpx;
}

.required {
  color: #f53f3f;
  margin-left: 6rpx;
}

.picker {
  font-size: 28rpx;
  color: #4e5969;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f0f2f5;
}

.textarea {
  width: 100%;
  min-height: 240rpx;
  font-size: 28rpx;
  color: #1d2129;
  line-height: 1.7;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f0f2f5;
}

.count {
  text-align: right;
  font-size: 24rpx;
  color: #86909c;
  margin-top: 16rpx;
}

.input {
  width: 100%;
  font-size: 28rpx;
  color: #1d2129;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f0f2f5;
}

/* --------------------------
   重点：强制覆盖按钮默认样式
--------------------------- */
.submit-btn {
  /* 强制重写背景色和渐变 */
  background: linear-gradient(135deg, #4080ff, #2962ff) !important;
  color: #ffffff !important;
  border-radius: 16rpx !important;
  margin-top: 36rpx !important;
  font-size: 32rpx !important;
  height: 92rpx !important;
  line-height: 92rpx !important;
  box-shadow: 0 6rpx 14rpx rgba(64, 128, 255, 0.28) !important;
  border: none !important;
}

/* 去掉小程序自带的边框 */
.submit-btn::after {
  border: none !important;
}

.submit-btn:active {
  opacity: 0.9 !important;
  transform: scale(0.98) !important;
}

.submit-btn.disabled {
  background: #c9cdd4 !important;
  color: #ffffff !important;
  box-shadow: none !important;
}

.tips {
  text-align: center;
  font-size: 24rpx;
  color: #86909c;
  margin-top: 28rpx;
  line-height: 1.6;
}