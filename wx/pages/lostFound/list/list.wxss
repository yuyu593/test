.filter-bar {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background-color: #f5f5f5;
}

.filter-item {
  padding: 10rpx 20rpx;
  background-color: white;
  border-radius: 8rpx;
  margin-right: 20rpx;
}

.address-input {
  flex: 1;
  padding: 10rpx;
  background-color: white;
  border-radius: 8rpx;
  margin: 0 10rpx;
}

.goods-list {
  padding: 20rpx;
}

.goods-item {
  display: flex;
  padding: 20rpx;
  border-bottom: 1px solid #eee;
  margin-bottom: 20rpx;
  background-color: white;
  border-radius: 10rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.goods-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
}

.goods-info {
  flex: 1;
}

.goods-name {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.goods-type {
  display: inline-block;
  padding: 4rpx 12rpx;
  background-color: #ecf5ff;
  color: #409eff;
  border-radius: 12rpx;
  font-size: 24rpx;
  margin-bottom: 10rpx;
}

.goods-desc {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.goods-address {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 5rpx;
}

.goods-time {
  font-size: 24rpx;
  color: #999;
}

.publish-btn {
  position: fixed;
  bottom: 100rpx;
  right: 40rpx;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  line-height: 120rpx;
  background-color: #409EFF;
  color: white;
  font-size: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(64, 158, 255, 0.4);
}