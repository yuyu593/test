/* pages/secondHand/detail/detail.wxss */
.detail-container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding: 20rpx;
}

/* 帖子头部信息 */
.post-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: white;
  padding: 20rpx;
  border-radius: 10rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 15rpx;
}

.user-details {
  flex: 1;
}

.nickname {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 5rpx;
}

.post-time {
  font-size: 24rpx;
  color: #999;
}

/* 帖子内容 */
.post-content {
  background-color: white;
  padding: 20rpx;
  border-radius: 10rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.goods-name {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.goods-info {
  margin-bottom: 20rpx;
}

.info-item {
  display: flex;
  margin-bottom: 10rpx;
}

.info-label {
  font-size: 28rpx;
  color: #666;
  width: 120rpx;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.goods-desc {
  font-size: 30rpx;
  color: #333;
  line-height: 1.5;
}

/* 图片展示 */
.image-gallery {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.gallery-img {
  width: 31%;
  aspect-ratio: 1;
  border-radius: 8rpx;
}

/* 操作栏 */
.action-bar {
  display: flex;
  justify-content: space-around;
  background-color: white;
  padding: 20rpx;
  border-radius: 10rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  cursor: pointer;
}

.action-icon {
  font-size: 40rpx;
  margin-bottom: 5rpx;
}

.action-text {
  font-size: 24rpx;
  color: #666;
}

/* 评论区 */
.comment-section {
  background-color: white;
  padding: 20rpx;
  border-radius: 10rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.comment-list {
  margin-bottom: 20rpx;
}

.comment-item {
  display: flex;
  margin-bottom: 20rpx;
}

.comment-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 15rpx;
}

.comment-content {
  flex: 1;
}

.comment-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.comment-nickname {
  font-size: 28rpx;
  font-weight: bold;
}

.comment-time {
  font-size: 24rpx;
  color: #999;
}

.comment-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
}

.empty-comments {
  text-align: center;
  color: #999;
  padding: 40rpx 0;
  font-size: 28rpx;
}

/* 评论输入区域 */
.comment-input-area {
  display: flex;
  align-items: center;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #eee;
}

.comment-input {
  flex: 1;
  padding: 15rpx;
  border: 1rpx solid #e6e6e6;
  border-radius: 20rpx;
  font-size: 28rpx;
  margin-right: 10rpx;
}

.comment-submit {
  padding: 15rpx 30rpx;
  background-color: #409eff;
  color: white;
  border-radius: 20rpx;
  font-size: 28rpx;
  border: none;
}

/* 响应式调整 */
@media (max-width: 750rpx) {
  .gallery-img {
    width: 30%;
  }
}
