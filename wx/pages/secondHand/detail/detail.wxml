<!--pages/secondHand/detail/detail.wxml-->
<view class="detail-container">
  <!-- 帖子头部信息 -->
  <view class="post-header">
    <view class="user-info">
      <image src="{{userInfo.avatar || 'https://picsum.photos/seed/user/100/100'}}" class="avatar" />
      <view class="user-details">
        <view class="nickname">{{userInfo.nickName || '校园用户'}}</view>
        <view class="post-time">{{postData.createTime}}</view>
      </view>
    </view>
  </view>

  <!-- 帖子内容 -->
  <view class="post-content">
    <view class="goods-name">{{postData.goodsName}}</view>
    <view class="goods-info">
      <view class="info-item">
        <text class="info-label">分类：</text>
        <text class="info-value">{{postData.goodsType}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">成色：</text>
        <text class="info-value">{{postData.quality}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">价格：</text>
        <text class="info-value">¥{{postData.price}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">交易地点：</text>
        <text class="info-value">{{postData.tradeAddress}}</text>
      </view>
    </view>
    <view class="goods-desc">{{postData.goodsDesc}}</view>
  </view>

  <!-- 图片展示 -->
  <view class="image-gallery" wx:if="{{postData.imgUrls}}">
    <image wx:for="{{imageList}}" wx:key="index" src="{{item}}" class="gallery-img" mode="aspectFill" bindtap="previewImage" data-index="{{index}}" />
  </view>

  <!-- 操作栏 -->
  <view class="action-bar">
    <view class="action-item" bindtap="handleLike">
      <text class="action-icon">{{isLiked ? '❤️' : '🤍'}}</text>
      <text class="action-text">{{likeCount}} 点赞</text>
    </view>
    <view class="action-item" bindtap="handleCollect">
      <text class="action-icon">{{isCollected ? '⭐' : '☆'}}</text>
      <text class="action-text">收藏</text>
    </view>
    <view class="action-item" bindtap="focusComment">
      <text class="action-icon">💬</text>
      <text class="action-text">{{commentCount}} 评论</text>
    </view>
  </view>

  <!-- 评论区 -->
  <view class="comment-section">
    <view class="section-title">评论 ({{commentCount}})</view>
    
    <!-- 评论列表 -->
    <view class="comment-list">
      <view class="comment-item" wx:for="{{comments}}" wx:key="id">
        <image src="{{item.avatar || 'https://picsum.photos/seed/comment/100/100'}}" class="comment-avatar" />
        <view class="comment-content">
          <view class="comment-header">
            <text class="comment-nickname">{{item.nickName}}</text>
            <text class="comment-time">{{item.createTime}}</text>
          </view>
          <text class="comment-text">{{item.content}}</text>
        </view>
      </view>
      <view wx:if="{{comments.length === 0}}" class="empty-comments">暂无评论，快来发表你的看法吧！</view>
    </view>

    <!-- 评论输入框 -->
    <view class="comment-input-area">
      <input placeholder="写下你的评论..." class="comment-input" value="{{commentContent}}" bindinput="handleCommentInput" />
      <button bindtap="handleSubmitComment" class="comment-submit">发送</button>
    </view>
  </view>
</view>
