.container {
  background: #f5f7fa;
  min-height: 100vh;
  padding-bottom: 20rpx;
}

.page-title {
  font-size: 42rpx;
  font-weight: bold;
  padding: 30rpx;
  color: #222;
}

.tab-wrap {
  display: flex;
  padding: 0 30rpx 20rpx;
  gap: 20rpx;
  overflow-x: auto;
}

.tab {
  padding: 14rpx 30rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
  background: #eaeaea;
  color: #666;
  white-space: nowrap;
}

.tab.active {
  background: #4B9EF7;
  color: #fff;
}

.list-box {
  padding: 0 20rpx;
}

.item {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.user-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.avatar {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  background: #f5f5f5;
}

.avatar-placeholder {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  background: #eaeaea;
}

.info {
  flex: 1;
}

.name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  display: block;
}

.time {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
  display: block;
}

.tag {
  padding: 6rpx 14rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
}

.tag.news {
  background: #f3e8ff;
  color: #722ed1;
}

.tag.purchase {
  background: #e6f7ff;
  color: #1890ff;
}

.tag.lost {
  background: #fff7e6;
  color: #fa8c16;
}

.tag.second {
  background: #f6ffed;
  color: #52c41a;
}

.content {
  margin-bottom: 20rpx;
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
  color: #222;
}

.desc {
  font-size: 28rpx;
  color: #555;
  line-height: 1.6;
}

.img-box {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}

.img {
  width: 210rpx;
  height: 210rpx;
  border-radius: 12rpx;
  background: #f5f5f5;

}