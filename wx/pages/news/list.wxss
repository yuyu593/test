page {
  background: #f5f7fa;
}
.page {
  padding: 30rpx;
}
.title {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
}

/* 标签栏 */
.tab-bar {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
}
.tab {
  padding: 12rpx 30rpx;
  border-radius: 30rpx;
  background: #f0f0f0;
  color: #666;
  font-size: 28rpx;
}
.tab.active {
  background: #409eff;
  color: #fff;
}

/* 卡片通用 */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
.user-info {
  display: flex;
  align-items: center;
}
.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}
.name {
  font-size: 30rpx;
  font-weight: bold;
}
.time {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}
.tag {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}
.tag.buy {
  background: #e6f0ff;
  color: #409eff;
}
.tag.lost {
  background: #fff3e6;
  color: #ff9800;
}

/* 卡片内容 */
.content-title {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
}
.content-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}
.price {
  font-size: 30rpx;
  color: #f56c6c;
  font-weight: bold;
  margin-top: 16rpx;
}

/* 失物卡片 */
.lost-content {
  display: flex;
  gap: 20rpx;
}
.lost-img {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
}

/* 图片组 */
.imgs {
  display: flex;
  gap: 10rpx;
  margin-top: 16rpx;
}
.imgs image {
  width: 150rpx;
  height: 150rpx;
  border-radius: 8rpx;
}