page {
  background-color: #f5f5f5;
}
.container {
  padding: 30rpx;
  padding-bottom: 200rpx;
}

.order-card, .pay-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.card-header {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.goods-info {
  display: flex;
}

.goods-img {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
}
.img-placeholder {
  width: 180rpx;
  height: 180rpx;
  background: linear-gradient(135deg, #f5f7fa 0%, #e4e8ef 100%);
  border-radius: 12rpx;
  margin-right: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 80rpx;
}

.goods-detail {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.goods-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 10rpx;
}

.goods-type {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.price {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff4444;
}

.pay-method {
  display: flex;
}

.method-item {
  flex: 1;
  display: flex;
  align-items: center;
  padding: 20rpx;
  border: 2rpx solid #eee;
  border-radius: 12rpx;
  margin-right: 20rpx;
}

.method-item.active {
  border-color: #409eff;
  background: #e0ebff;
}

.method-item .icon {
  font-size: 40rpx;
  margin-right: 15rpx;
}

.method-item .name {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.method-item .check {
  color: #409eff;
  font-weight: bold;
}

.amount-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.amount-label {
  font-size: 28rpx;
  color: #666;
}

.amount-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #ff4444;
}

.pay-btn {
  flex: 2;
  height: 90rpx;
  line-height: 90rpx;
  background: #ff4444;
  color: #fff;
  font-size: 32rpx;
  border-radius: 45rpx;
  border: none;
  margin: 0;
  padding: 0;
}

.cancel-btn {
  flex: 1;
  height: 90rpx;
  line-height: 90rpx;
  background: #f0f0f0;
  color: #666;
  font-size: 28rpx;
  border-radius: 45rpx;
  text-align: center;
  margin-right: 20rpx;
}

.btn-group {
  display: flex;
  align-items: center;
  padding: 0 30rpx;
}

.empty {
  text-align: center;
  color: #999;
  padding: 40rpx;
}