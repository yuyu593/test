page {
  background-color: #f5f5f5;
}
.container {
  padding-bottom: 200rpx;
}

.tab-wrap {
  display: flex;
  background: #fff;
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid #eee;
}

.tab {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: #666;
  padding: 15rpx 0;
}

.tab.active {
  color: #409eff;
  font-weight: bold;
  position: relative;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: #409eff;
  border-radius: 2rpx;
}

.order-list {
  padding: 30rpx;
}

.order-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.order-id {
  font-size: 26rpx;
  color: #999;
}

.status {
  font-size: 26rpx;
  font-weight: 500;
}

.status.pending { color: #ff9800; }
.status.paid { color: #409eff; }
.status.completed { color: #36d399; }
.status.cancelled { color: #999; }

.goods-info {
  display: flex;
  padding: 20rpx 0;
  border-top: 1rpx solid #f5f5f5;
  border-bottom: 1rpx solid #f5f5f5;
}

.goods-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
}
.img-placeholder {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, #f5f7fa 0%, #e4e8ef 100%);
  border-radius: 12rpx;
  margin-right: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 70rpx;
}

.goods-detail {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.goods-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 10rpx;
}

.goods-type {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.price {
  font-size: 34rpx;
  font-weight: bold;
  color: #ff4444;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
}

.create-time {
  font-size: 24rpx;
  color: #999;
}

.actions {
  display: flex;
}

.action-btn {
  width: 120rpx;
  height: 60rpx;
  line-height: 60rpx;
  font-size: 26rpx;
  border-radius: 30rpx;
  margin-left: 15rpx;
}

.action-btn.pay {
  background: #ff4444;
  color: #fff;
  border: none;
}

.action-text {
  font-size: 26rpx;
  color: #999;
  margin-left: 15rpx;
}

.empty {
  text-align: center;
  color: #999;
  padding: 80rpx 0;
}