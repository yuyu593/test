<view class="container">
  <view class="tab-wrap">
    <view class="tab {{currentTab==''?'active':''}}" bindtap="switchTab" data-type="">全部</view>
    <view class="tab {{currentTab=='0'?'active':''}}" bindtap="switchTab" data-type="0">待付款</view>
    <view class="tab {{currentTab=='1'?'active':''}}" bindtap="switchTab" data-type="1">已付款</view>
  </view>

  <view class="order-list">
    <view class="order-card" wx:for="{{orderList}}" wx:key="recordId">
      <view class="order-header">
        <text class="order-id">订单号：{{item.recordId}}</text>
        <text class="status {{getStatusClass(item.status)}}">{{getStatusText(item.status)}}</text>
      </view>
      <view class="goods-info">
        <image wx:if="{{item.imgUrls}}" src="{{baseUrl + item.imgUrls}}" class="goods-img"></image>
        <view wx:else class="img-placeholder">📦</view>
        <view class="goods-detail">
          <view class="goods-name">{{item.goodsName}}</view>
          <view class="goods-type">{{item.goodsType}}</view>
          <view class="price">¥{{item.price}}</view>
        </view>
      </view>
      <view class="order-footer">
        <text class="create-time">{{formatTime(item.createTime)}}</text>
        <view class="actions">
          <button wx:if="{{item.status === 0}}" class="action-btn pay" bindtap="goPay" data-id="{{item.recordId}}">去付款</button>
          <text wx:else-if="{{item.status === 1}}" class="action-text">已付款</text>
        </view>
      </view>
    </view>
    <view class="empty" wx:if="{{orderList.length === 0}}">暂无订单</view>
  </view>
</view>