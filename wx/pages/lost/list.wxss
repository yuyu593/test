page { background: #f5f7fa; }
.page { padding: 30rpx; }

.header { display: flex; justify-content: space-between; align-items: center; padding: 20rpx 0 30rpx; }
.title { font-size: 36rpx; font-weight: bold; }
.publish-btn { background: #409eff; color: #fff; padding: 12rpx 30rpx; border-radius: 40rpx; font-size: 26rpx; }

.tabs { display: flex; margin-bottom: 20rpx; background: #fff; border-radius: 16rpx; padding: 8rpx; }
.tab { flex: 1; text-align: center; padding: 16rpx 0; font-size: 28rpx; color: #666; border-radius: 12rpx; }
.tab.active { background: #409eff; color: #fff; }

.list { height: calc(100vh - 230rpx); }

.card { background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 20rpx; position: relative; }
.type-tag { position: absolute; top: 24rpx; right: 24rpx; padding: 6rpx 16rpx; border-radius: 8rpx; font-size: 22rpx; }
.type-tag.lost { background: #ffe0e0; color: #ff4d4f; }
.type-tag.found { background: #e0ffeb; color: #00b578; }

.card-content { display: flex; }
.img { width: 160rpx; height: 160rpx; border-radius: 12rpx; margin-right: 20rpx; }
.info { flex: 1; }
.goods-name { font-size: 30rpx; font-weight: bold; margin-bottom: 8rpx; color: #333; }
.address { font-size: 24rpx; color: #666; margin-bottom: 8rpx; }
.desc { font-size: 26rpx; color: #999; overflow: hidden; text-overflow: ellipsis;
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-line-clamp: 2; margin-bottom: 8rpx; }
.time { font-size: 22rpx; color: #bbb; }

.empty { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 100rpx 0; }
.empty-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.empty-text { font-size: 28rpx; color: #999; }
