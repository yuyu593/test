<view class="page">
  <!-- 顶部标题和发布按钮 -->
  <view class="header">
    <view class="title">失物招领</view>
    <view class="publish-btn" bindtap="goPublish">+ 发布</view>
  </view>

  <!-- 分类筛选 -->
  <view class="tabs">
    <view class="tab {{currentTab === '' ? 'active' : ''}}" bindtap="switchTab" data-type="">全部</view>
    <view class="tab {{currentTab === '1' ? 'active' : ''}}" bindtap="switchTab" data-type="1">寻物启事</view>
    <view class="tab {{currentTab === '2' ? 'active' : ''}}" bindtap="switchTab" data-type="2">失物招领</view>
  </view>

  <!-- 列表 -->
  <scroll-view scroll-y class="list">
    <view wx:if="{{list.length === 0}}" class="empty">
      <view class="empty-icon">📭</view>
      <view class="empty-text">暂无数据</view>
    </view>

    <view wx:for="{{list}}" wx:key="lostId" class="card" bindtap="goDetail" data-id="{{item.lostId}}">
      <!-- 标签 -->
      <view class="type-tag {{item.type === 1 ? 'lost' : 'found'}}">{{item.type === 1 ? '寻物启事' : '失物招领'}}</view>

      <view class="card-content">
        <image wx:if="{{item.imgUrl}}" class="img" src="{{item.imgUrl}}" mode="aspectFill"></image>
        <view class="info">
          <view class="goods-name">{{item.goodsName}}</view>
          <view class="address">📍 {{item.address}}</view>
          <view class="desc">{{item.goodsDesc}}</view>
          <view class="time">发布时间：{{item.timeStr}}</view>
        </view>
      </view>
    </view>
  </scroll-view>
</view>
