<view class="container">
  <!-- 用户信息 -->
  <view class="user-box" wx:if="{{detail}}">
    <image wx:if="{{detail.avatar}}" src="{{baseUrl + detail.avatar}}" class="avatar"></image>
    <view wx:else class="avatar" style="background:#f0f0f0;display:flex;align-items:center;justify-content:center;font-size:36rpx;">👤</view>
    <view class="user-info">
      <text class="nickname">{{detail.nickname || '匿名用户'}}</text>
      <text class="create-time">{{detail.createTime}}</text>
    </view>
  </view>

  <!-- 失物招领信息卡片 -->
  <view class="goods-info">
    <view class="title-wrap">
      <view class="goods-title">
        <text wx:if="{{detail.type == 1}}" style="color: #ff4444;">【寻物】</text>
        <text wx:else style="color: #00b578;">【失物招领】</text>
        {{detail.goodsName}}
      </view>
    </view>

    <view wx:if="{{detail.imgUrls}}" class="img-wrap">
      <image class="main-img" src="{{detail.imgUrls}}" mode="aspectFill"></image>
    </view>

    <view class="attr-row">
      <text class="attr-label">地点</text>
      <text class="attr-text">{{detail.address}}</text>
    </view>
    <view class="attr-row" wx:if="{{detail.happenTime}}">
      <text class="attr-label">时间</text>
      <text class="attr-text">{{detail.happenTime}}</text>
      <button class="contact-btn" bindtap="showSendMsg">💬 私信</button>
    </view>
    <view wx:if="{{!detail.happenTime}}" class="attr-row">
      <button class="contact-btn" bindtap="showSendMsg">💬 私信发布者</button>
    </view>

    <view class="desc-wrap">
      <view class="desc-title">详细描述</view>
      <view class="desc-content">{{detail.goodsDesc}}</view>
    </view>
  </view>

  <!-- 评论区 -->
  <view class="comment-wrap">
    <view class="comment-title">全部评论</view>
    <view class="comment-item" wx:for="{{commentList}}" wx:key="index">
      <image class="avatar" src="{{item.avatar}}"></image>
      <view class="comment-right">
        <view class="name">{{item.nickname}}</view>
        <view class="content">{{item.content}}</view>
        <view class="time">{{item.createTime}}</view>
      </view>
    </view>
    <view class="empty" wx:if="{{commentList.length == 0}}">暂无评论，快来抢沙发~</view>
  </view>

  <!-- 评论输入框 -->
  <view class="comment-input-wrap">
    <input class="input" placeholder="说点什么..." bindinput="onInputComment" value="{{commentContent}}"/>
    <button class="submit-btn" bindtap="submitComment">发布</button>
  </view>
</view>

<!-- 私信弹窗 -->
<view wx:if="{{showMsgModal}}" class="modal-mask" catchtap="hideSendMsg">
  <view class="modal-card" catchtap="noop">
    <view class="modal-title">发私信给 {{detail.nickname || '发布者'}}</view>
    <textarea class="modal-input" placeholder="请输入私信内容..." value="{{msgContent}}" bindinput="onMsgInput" maxlength="200" auto-height></textarea>
    <view class="modal-actions">
      <button class="modal-cancel" bindtap="hideSendMsg">取消</button>
      <button class="modal-confirm" bindtap="doSendMsg">发送</button>
    </view>
  </view>
</view>
