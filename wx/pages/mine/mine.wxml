<view class="page">
  <!-- 顶部蓝色区域 -->
  <view class="header">
    <view class="user-info">
      <!-- 头像 -->
      <image wx:if="{{user.avatar}}" src="{{baseUrl + user.avatar}}" class="avatar" />
      <view wx:else class="avatar default-avatar">👤</view>
      <view class="text">
        <view class="name">
          {{user.nickName || '用户'}}
          <text class="vip-tag">VIP 极速达</text>
        </view>
        <view class="dept">广州软件学院</view>
      </view>
    </view>
    <view class="settings-icon" bindtap="goEditProfile">⚙️</view>

    <!-- 信用分卡片 -->
    <view class="credit-card">
      <view class="left">
        <text class="shield-icon">🛡️</text>
        <text>信用水平：卓越</text>
      </view>
      <view class="score">{{user.creditScore || 100}}</view>
    </view>
  </view>

  <!-- 数据统计 -->
  <view class="stats">
    <view class="stat-item" bindtap="gomypublish">
      <view class="num">{{user.publishCount != null ? user.publishCount : 0}}</view>
      <view class="label">我发布的</view>
    </view>
    <view class="stat-item" bindtap="goSell">
      <view class="num">{{user.soldCount != null ? user.soldCount : 0}}</view>
      <view class="label">我卖出的</view>
    </view>
    <view class="stat-item" bindtap="goBuy">
      <view class="num">{{user.buyCount != null ? user.buyCount : 0}}</view>
      <view class="label">我买到的</view>
    </view>
  </view>

  <!-- 功能列表 -->
  <view class="menu">
    <view class="menu-item" bindtap="goCollect">
      <text class="icon blue">💙</text>
      <text class="name">我的收藏</text>
      <text class="arrow">></text>
    </view>
    <!-- 浏览记录 绑定点击跳转 -->
    <view class="menu-item" bindtap="goHistory">
      <text class="icon green">♻️</text>
      <text class="name">浏览记录</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item">
      <text class="icon orange">🪪</text>
      <text class="name">实名认证</text>
      <text class="status">已认证</text>
      <text class="arrow"></text>
    </view>
    <view class="menu-item" bindtap="goFeedback">
      <text class="icon purple">🎧</text>
      <text class="name">客服与反馈</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="goToAbout">
      <text class="icon">ℹ️</text>
      <text class="name">关于平台</text>
      <text class="arrow">></text>
    </view>
  </view>

  <!-- 退出登录按钮 -->
  <button class="logout-btn" bindtap="logout">退出登录</button>
</view>