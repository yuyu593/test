page { background: #f5f7fa; }
.page { padding: 30rpx; }
.header { padding: 20rpx 0 30rpx; display: flex; justify-content: space-between; align-items: center; }
.title { font-size: 36rpx; font-weight: bold; }
.action { font-size: 26rpx; color: #409eff; }
.list { height: calc(100vh - 150rpx); }

.msg-item {
  display: flex; align-items: center; background: #fff; border-radius: 16rpx;
  padding: 24rpx; margin-bottom: 16rpx; position: relative;
}
.avatar { width: 80rpx; height: 80rpx; border-radius: 50%; display: flex; align-items: center;
  justify-content: center; font-size: 32rpx; margin-right: 20rpx; flex-shrink: 0; }
.avatar.system { background: #e0ebff; color: #409eff; }
.avatar.user { background: #e8f8ee; color: #36d399; }
.content { flex: 1; }
.row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8rpx; }
.name { font-size: 30rpx; font-weight: bold; }
.time { font-size: 24rpx; color: #999; }
.desc { font-size: 26rpx; color: #666; overflow: hidden; text-overflow: ellipsis;
  display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; }
.badge { min-width: 40rpx; height: 40rpx; line-height: 40rpx; padding: 0 12rpx; background: #ff4d4f; color: #fff;
  border-radius: 20rpx; position: absolute; right: 24rpx; top: 30rpx; transform: none;
  font-size: 24rpx; text-align: center; font-weight: bold; box-shadow: 0 2rpx 8rpx rgba(255,77,79,0.4); }

.empty { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 100rpx 0; }
.empty-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.empty-text { font-size: 28rpx; color: #999; }

.quick-chat {
  display: inline-block;
  margin-top: 16rpx;
  padding: 10rpx 24rpx;
  background: linear-gradient(135deg, #409eff 0%, #67c23a 100%);
  color: #fff;
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(64, 158, 255, 0.3);
}
