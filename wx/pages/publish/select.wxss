page {
  background: linear-gradient(to bottom, #f0f7ff, #ffffff);
}
.container {
  padding: 80rpx 40rpx;
}

/* 标题区域 */
.header {
  text-align: center;
  margin-bottom: 80rpx;
}
.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-bottom: 20rpx;
}
.subtitle {
  font-size: 28rpx;
  color: #666;
}

/* 选项列表 */
.list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}
.item {
  display: flex;
  align-items: center;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}
.icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 24rpx;
}
.icon.blue { background: #e0ebff; color: #409eff; }
.icon.green { background: #e8f8ee; color: #36d399; }
.icon.purple { background: #f5ebff; color: #b37feb; }
.icon.orange { background: #fff3e6; color: #ff9800; }
.text {
  flex: 1;
}
.name {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}
.desc {
  font-size: 26rpx;
  color: #666;
}
.arrow {
  font-size: 32rpx;
  color: #999;
}

/* 底部提示 */
.notice {
  margin-top: 80rpx;
  text-align: center;
  font-size: 24rpx;
  color: #999;
  line-height: 1.6;
}

/* 关闭按钮 */
.close-btn {
  position: fixed;
  bottom: 60rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 80rpx;
  height: 80rpx;
  background: #ffffff;
  border-radius: 50%;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #666;
}