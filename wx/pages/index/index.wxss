page {
  background: #f5f5f5;
}
.page {
  padding: 30rpx;
}

/* 顶部定位+搜索栏 */
.top-bar {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}
.location {
  display: flex;
  align-items: center;
  color: #409eff;
  font-weight: bold;
}
.loc-icon {
  font-size: 28rpx;
  margin-right: 6rpx;
}
.search-box {
  flex: 1;
  background: #eee;
  border-radius: 50rpx;
  padding: 16rpx 24rpx;
  margin-left: 20rpx;
  display: flex;
  align-items: center;
  position: relative;
}
.search-icon {
  margin-right: 12rpx;
  color: #999;
}
.search-box input {
  flex: 1;
  font-size: 28rpx;
}
.clear-btn {
  position: absolute;
  right: 20rpx;
  background: #ddd;
  color: #666;
  border-radius: 50%;
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  font-size: 24rpx;
}

/* 轮播图 */
.banner {
  width: 100%;
  height: 300rpx;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 30rpx;
}
.banner image {
  width: 100%;
  height: 100%;
}

/* 分类图标 */
.category-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 30rpx;
  margin-bottom: 40rpx;
}
.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-bottom: 12rpx;
}
.icon.blue { background: #e0ebff; color: #409eff; }
.icon.green { background: #d8f8e8; color: #36d399; }
.icon.orange { background: #ffe8cc; color: #ff9800; }
.icon.purple { background: #f0e6ff; color: #b37feb; }
.icon.pink { background: #ffe0eb; color: #f472b6; }
.icon.teal { background: #d6f5f0; color: #14b8a6; }
.icon.yellow { background: #fff9cc; color: #facc15; }
.icon.grey { background: #f0f0f0; color: #999; }
.name {
  font-size: 26rpx;
  color: #333;
}

/* 猜你喜欢 */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
.title {
  font-size: 34rpx;
  font-weight: bold;
}
.desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}
.more {
  font-size: 26rpx;
  color: #409eff;
}
.goods-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}
.goods-card {
  background: white;
  border-radius: 12rpx;
  overflow: hidden;
}
.goods-card image {
  width: 100%;
  height: 260rpx;
}
.info {
  padding: 16rpx;
}
.title {
  font-size: 28rpx;
  color: #333;
}
.tags {
  display: flex;
  margin-top: 12rpx;
}
.tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  margin-right: 10rpx;
}
.tag.quality {
  background: #fee;
  color: #f56c6c;
}
.tag.seller {
  background: #f0f0f0;
  color: #666;
}

/* 搜索结果 */
.result-section {
  margin-top: 20rpx;
}
.empty {
  text-align: center;
  padding: 60rpx;
  color: #999;
}