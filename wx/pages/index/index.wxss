page {
  background: #f5f5f5;
}
.page {
  padding: 30rpx;
}

/* 顶部定位+搜索栏 */
.top-bar {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}
.location {
  display: flex;
  align-items: center;
  color: #409eff;
  font-weight: bold;
}
.loc-icon {
  font-size: 28rpx;
  margin-right: 6rpx;
}
.search-box {
  flex: 1;
  background: #eee;
  border-radius: 50rpx;
  padding: 16rpx 24rpx;
  margin-left: 20rpx;
  display: flex;
  align-items: center;
  position: relative;
}
.search-icon {
  margin-right: 12rpx;
  color: #999;
}
.search-box input {
  flex: 1;
  font-size: 28rpx;
}
.clear-btn {
  position: absolute;
  right: 20rpx;
  background: #ddd;
  color: #666;
  border-radius: 50%;
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  font-size: 24rpx;
}

/* 轮播图 */
.banner {
  width: 100%;
  height: 300rpx;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 30rpx;
}
.banner-slide {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}
.gradient-blue {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}
.gradient-green {
  background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
}
.gradient-orange {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

/* 分类图标 */
.category-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 30rpx;
  margin-bottom: 40rpx;
}
.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-bottom: 12rpx;
}
.icon.blue { background: #e0ebff; color: #409eff; }
.icon.green { background: #d8f8e8; color: #36d399; }
.icon.orange { background: #ffe8cc; color: #ff9800; }
.icon.purple { background: #f0e6ff; color: #b37feb; }
.icon.pink { background: #ffe0eb; color: #f472b6; }
.icon.teal { background: #d6f5f0; color: #14b8a6; }
.icon.yellow { background: #fff9cc; color: #facc15; }
.icon.grey { background: #f0f0f0; color: #999; }
.name {
  font-size: 26rpx;
  color: #333;
}

/* 猜你喜欢 */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
.title {
  font-size: 34rpx;
  font-weight: bold;
}
.desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}
.more {
  font-size: 26rpx;
  color: #409eff;
}
.goods-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}
.goods-card {
  background: white;
  border-radius: 16rpx;
  overflow: hidden;
}
.goods-card image {
  width: 100%;
  height: 320rpx;
}
.img-placeholder {
  width: 100%;
  height: 320rpx;
  background: linear-gradient(135deg, #f5f7fa 0%, #e4e8ef 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 120rpx;
}
.info {
  padding: 20rpx;
}
.goods-name {
  font-size: 30rpx;
  color: #000000;
  font-weight: bold;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.price {
  font-size: 32rpx;
  font-weight: bold;
  color: #ff4444;
  margin-bottom: 6rpx;
}
.type {
  font-size: 24rpx;
  color: #999;
}

/* 搜索结果 */
.result-section {
  margin-top: 20rpx;
}
.empty {
  text-align: center;
  padding: 60rpx;
  color: #999;
}