<view class="page">
  <!-- 顶部定位+搜索栏 -->
  <view class="top-bar">
    <view class="location">
      <text class="loc-icon">📍</text>
      <text class="loc-text">广软校区</text>
    </view>
    <view class="search-box">
      <text class="search-icon">🔍</text>
      <input 
        placeholder="搜索你想要的商品" 
        bindinput="onSearchInput"
        bindconfirm="doSearch"
        value="{{searchKey}}"
      />
      <button wx:if="{{searchKey}}" bindtap="clearSearch" class="clear-btn">×</button>
    </view>
  </view>

  <!-- 轮播图 -->
  <swiper class="banner" indicator-dots autoplay circular>
    <swiper-item>
      <image src="https://picsum.photos/seed/campus/750/300" mode="widthFix"></image>
    </swiper-item>
    <swiper-item>
      <image src="https://picsum.photos/seed/school/750/300" mode="widthFix"></image>
    </swiper-item>
  </swiper>

  <!-- 分类图标区 -->
  <view class="category-grid">
    <view class="category-item" wx:for="{{categories}}" wx:key="index">
      <view class="icon {{item.color}}">{{item.icon}}</view>
      <text class="name">{{item.name}}</text>
    </view>
  </view>

  <!-- 搜索结果（输入关键词时显示） -->
  <view wx:if="{{searchKey}}" class="result-section">
    <view class="section-title">搜索结果</view>
    <view class="goods-card" wx:for="{{searchResult}}" wx:key="id">
      <image src="{{item.img || 'https://picsum.photos/seed/'+item.id+'/300/300'}}" mode="aspectFill"></image>
      <view class="info">
        <view class="title">{{item.goodsName}}</view>
        <view class="tags">
          <text class="tag quality">{{item.quality}}</text>
          <text class="tag seller">{{item.seller}}</text>
        </view>
      </view>
    </view>
    <view wx:if="{{searchResult.length === 0}}" class="empty">暂无相关商品</view>
  </view>

  <!-- 默认猜你喜欢（无搜索时显示） -->
  <view wx:else>
    <view class="section-header">
      <view>
        <text class="title">猜你喜欢</text>
        <text class="desc">2026年3月22日 实时更新</text>
      </view>
      <text class="more" bindtap="goList">查看更多</text>
    </view>
    <view class="goods-grid">
      <view class="goods-card" wx:for="{{recommendGoods}}" wx:key="id">
        <image src="{{item.img || 'https://picsum.photos/seed/'+item.id+'/300/300'}}" mode="aspectFill"></image>
        <view class="info">
          <view class="title">{{item.goodsName}}</view>
          <view class="tags">
            <text class="tag quality">{{item.quality}}</text>
            <text class="tag seller">{{item.seller}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>