/* pages/about/about.wxss */
.container {
  background-color: #f5f7fa;
  min-height: 100vh;
  padding: 24rpx;
}

/* 头部样式 */
.header {
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 48rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.logo-box {
  width: 140rpx;
  height: 140rpx;
  background: linear-gradient(135deg, #eaf4ff 0%, #dceeff 100%);
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.logo-icon {
  font-size: 70rpx;
}

.platform-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}

.version {
  font-size: 24rpx;
  color: #888888;
}

/* 通用卡片样式 */
.card {
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 24rpx;
}

.card-content {
  font-size: 26rpx;
  color: #555555;
  line-height: 1.7;
  letter-spacing: 0.5rpx;
}

/* 核心功能网格 */
.feature-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.feature-item {
  width: 46%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
}

.icon-box {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.icon-text {
  font-size: 40rpx;
}

.icon-box.blue {
  background-color: #e6f4ff;
}
.icon-box.green {
  background-color: #e6ffed;
}
.icon-box.orange {
  background-color: #fff7e6;
}
.icon-box.purple {
  background-color: #f6e6ff;
}

.feature-text {
  font-size: 26rpx;
  color: #555555;
  text-align: center;
}

/* 开发者信息 */
.info-row {
  display: flex;
  margin-bottom: 16rpx;
  line-height: 1.6;
}

.label {
  font-size: 26rpx;
  color: #888888;
  width: 180rpx;
  flex-shrink: 0;
}

.value {
  font-size: 26rpx;
  color: #333333;
  flex: 1;
  word-break: break-all;
}

/* 版权信息 */
.copyright {
  text-align: center;
  font-size: 22rpx;
  color: #aaaaaa;
  margin-top: 40rpx;
  padding-bottom: 40rpx;
}