page{
  background:#f0f7ff;
  padding:30rpx;
}
.item-box{
  background:#fff;
  border-radius:20rpx;
  padding:32rpx;
  margin-bottom:24rpx;
  display:flex;
  justify-content:space-between;
}
.item-left{
  flex:1;
}
.title{
  font-size:36rpx;
  font-weight:bold;
  color:#222;
}
.desc{
  font-size:28rpx;
  color:#666;
  margin:12rpx 0;
}
.time{
  font-size:26rpx;
  color:#999;
}
.tag-xian{
  background:#dcf8d9;
  color:#36b32e;
  padding:8rpx 20rpx;
  border-radius:30rpx;
  font-size:26rpx;
}
.tag-qiu{
  background:#e1f0ff;
  color:#2688ed;
  padding:8rpx 20rpx;
  border-radius:30rpx;
  font-size:26rpx;
}
.tag-dong{
  background:#f3e8ff;
  color:#9456d9;
  padding:8rpx 20rpx;
  border-radius:30rpx;
  font-size:26rpx;
}
.tag-shi{
  background:#ffeede;
  color:#ff7828;
  padding:8rpx 20rpx;
  border-radius:30rpx;
  font-size:26rpx;
}
.empty{
  text-align:center;
  margin-top:200rpx;
  color:#999;
  font-size:30rpx;
}