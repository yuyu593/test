page {
  background: #fff;
  padding: 10rpx;
}
.title {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 40rpx;
}

.container {
  padding: 30rpx;
  background-color: #fff;
  min-height: 100vh;
}

.form-item {
  margin-bottom: 40rpx;
}

.label {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.input, .textarea, .picker {
  width: 100%;
  background-color: #f5f5f5;
  border-radius: 16rpx;
  padding: 24rpx;
  box-sizing: border-box;
  font-size: 28rpx;
}

.textarea {
  min-height: 200rpx;
}

.upload-area {
  display: flex;
  height: 250rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  align-items: center;
  justify-content: center;
}

.add-btn {
  width: 200rpx;
  height: 200rpx;
  background-color: #f5f5f5;
  border-radius: 16rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.plus-icon {
  font-size: 60rpx;
  color: #999;
}

.preview-img {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.tag {
  padding: 10rpx 32rpx;
  background-color: #f5f5f5;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #666;
  line-height: 1;
}

.tag.active {
  background-color: #e6f7ff;
  color: #1890ff;
}

.submit-btn {
  width: 100%;
  background-color: #409eff;
  color: white;
  border-radius: 50rpx;
  padding: 24rpx 0;
  font-size: 32rpx;
}

.card-picker {
  margin-bottom: 0;
  padding: 30rpx 24rpx;
  color: #666;
  font-size: 28rpx;
  background: #f5f5f5;
}

.picker-text {
  background: transparent;
  font-size: inherit;
  color: inherit;
  width: auto;
}