.container {
  padding: 30rpx;
  background: #fff;
  min-height: 100vh;
}

.page-title {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 40rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.flex-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.label {
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 16rpx;
  display: block;
}

.input, .picker {
  background: #f5f7fa;
  border-radius: 12rpx;
  padding: 25rpx;
  font-size: 28rpx;
}

.picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.arrow {
  color: #999;
  font-size: 32rpx;
}

.textarea {
  background: #f5f7fa;
  border-radius: 12rpx;
  padding: 25rpx;
  min-height: 220rpx;
  font-size: 28rpx;
}

.switch-group {
  display: flex;
  background: #f5f7fa;
  border-radius: 12rpx;
  overflow: hidden;
}

.switch {
  padding: 15rpx 40rpx;
  font-size: 28rpx;
}

.switch.active {
  background: #4A90E2;
  color: #fff;
}

.submit-btn {
  width: 100%;
  background: #4A90E2;
  color: #fff;
  border-radius: 50rpx;
  padding: 25rpx;
  font-size: 32rpx;
  margin-top: 60rpx;
}