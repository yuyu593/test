page {
  background-color: #f5f5f5;
}
.container {
  padding: 24rpx;
  box-sizing: border-box;
  padding-bottom: 120rpx;
}

/* 用户栏 */
.user-box {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}
.avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}
.user-info {
  display: flex;
  flex-direction: column;
}
.nickname {
  font-size: 30rpx;
  color: #333;
}
.create-time {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

/* 物品图片 */
.img-wrap {
  width: 100%;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}
.goods-img {
  width: 100%;
  height: 460rpx;
}

/* 物品信息卡片 */
.goods-info {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}
.goods-title {
  font-size: 32rpx;
  color: #222;
  font-weight: 500;
  margin-bottom: 25rpx;
}
.attr-row {
  display: flex;
  margin-bottom: 12rpx;
  font-size: 28rpx;
}
.attr-label {
  color: #666;
  width: 140rpx;
}
.attr-text {
  color: #333;
  flex: 1;
}
.desc-wrap {
  margin-top: 30rpx;
  padding-top: 25rpx;
  border-top: 1rpx solid #eee;
}
.desc-title {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 12rpx;
}
.desc-content {
  font-size: 28rpx;
  color: #555;
  line-height: 1.7;
}

/* 评论区 */
.comment-wrap {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 120rpx;
}
.comment-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}
.comment-item {
  display: flex;
  margin-bottom: 30rpx;
}
.comment-item .avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
}
.comment-right {
  margin-left: 20rpx;
  flex: 1;
}
.comment-right .name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}
.comment-right .content {
  font-size: 28rpx;
  color: #444;
  margin: 8rpx 0;
  line-height: 1.6;
}
.comment-right .time {
  font-size: 22rpx;
  color: #999;
}
.empty {
  font-size: 26rpx;
  color: #999;
  text-align: center;
  padding: 40rpx 0;
}

/* 评论输入框 */
.comment-input-wrap {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  background: #fff;
  display: flex;
  align-items: center;
  padding: 20rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05);
}
.input {
  flex: 1;
  height: 70rpx;
  background: #f5f5f5;
  border-radius: 35rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
}
.submit-btn {
  width: 120rpx;
  height: 70rpx;
  line-height: 70rpx;
  background: #0088ff;
  color: #fff;
  font-size: 28rpx;
  border-radius: 35rpx;
  margin-left: 20rpx;
  text-align: center;
  border: none;
  padding: 0;
}
/* 标题+爱心行 */
.title-wrap {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 25rpx;
}

/* 爱心收藏按钮 */
.heart-btn {
  font-size: 60rpx;
  color: #cccccc !important;
  transition: all 0.2s;
}
.heart-btn.collected {
  color: #ff4444 !important;
  transform: scale(1.1);
}