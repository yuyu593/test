<view class="page">
  <view class="title">失物招领</view>

  <view class="form-item">
    <view class="label">物品名称</view>
    <input class="input-item" placeholder="遗失物品名称" bindinput="onNameInput" value="{{form.goodsName}}"/>
  </view>

  <view class="form-item">
    <view class="label">物品分类</view>
    <picker mode="selector" range="{{categoryList}}" bindchange="onCategoryChange">
      <view class="picker-text">{{form.category || '请选择分类'}}</view>
    </picker>
  </view>

  <view class="form-item">
    <view class="label">丢失/拾取地点</view>
    <input class="input-item" placeholder="请输入地点" bindinput="onAddressInput" value="{{form.address}}"/>
  </view>

  <view class="form-item">
    <view class="label">联系电话</view>
    <input class="input-item" placeholder="请输入联系电话" bindinput="onPhoneInput" value="{{form.phone}}"/>
  </view>

  <view class="form-item">
    <view class="label">物品照片</view>
    <view class="upload-area" bindtap="chooseImage">
      <image wx:if="{{form.imgUrl}}" src="{{form.imgUrl}}" mode="aspectFill"></image>
      <view wx:else class="add-icon">+</view>
    </view>
  </view>

  <view class="form-item">
    <view class="label">物品描述与遗失详情</view>
    <textarea class="input-item textarea-item" placeholder="例如：4月19日下午6点在图书馆丢失..." maxlength="300" bindinput="onDescInput" value="{{form.description}}"></textarea>
  </view>

  <button class="submit-btn" bindtap="submit">发布</button>
</view>