<view class="container">
  <view class="title">闲置物品发布</view>

  <!-- 物品名称 -->
  <view class="form-item">
    <text class="label">物品名称</text>
    <input 
      class="input" 
      placeholder="请输入物品名称" 
      bindinput="onGoodsName" 
      value="{{form.goodsName}}" 
    />
  </view>

  <!-- 物品分类 -->
  <view class="form-item">
    <text class="label">物品分类</text>
    <picker range="{{categoryList}}" bindchange="onGoodsType">
      <view class="card-picker">
        <text class="picker-text">{{form.goodsType || '请选择分类'}}</text>
      </view>
    </picker>
  </view>

  <!-- 物品价格 -->
  <view class="form-item">
    <text class="label">物品价格</text>
    <input 
      class="input" 
      type="digit" 
      placeholder="请输入价格" 
      bindinput="onPrice" 
      value="{{form.price}}" 
    />
  </view>

  <!-- 交易地点 -->
  <view class="form-item">
    <text class="label">交易地点</text>
    <input 
      class="input" 
      placeholder="请输入交易地点" 
      bindinput="onTradeAddress" 
      value="{{form.tradeAddress}}" 
    />
  </view>

  <!-- 物品图片 -->
  <view class="form-item">
    <text class="label">物品图片</text>
    <view class="upload-area" bindtap="chooseImage">
      <image wx:if="{{form.imgUrls}}" src="{{form.imgUrls}}" class="preview-img"></image>
      <view wx:else class="add-btn">
        <text class="plus-icon">+</text>
      </view>
    </view>
  </view>

  <!-- 物品描述 -->
  <view class="form-item">
    <text class="label">物品描述</text>
    <textarea 
      class="textarea" 
      placeholder="请输入物品描述" 
      bindinput="onGoodsDesc" 
      value="{{form.goodsDesc}}"
    ></textarea>
  </view>

  <!-- 发布按钮 -->
  <button class="submit-btn" bindtap="submit">发布闲置</button>
</view>